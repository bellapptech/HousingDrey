@model IEnumerable<HousingDrey.Models.Property>

@{
    ViewData["Title"] = "HousingDrey - Liste des biens";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🏠 HousingDrey - Gestion Immobilière</h2>
        <a class="btn btn-primary" asp-action="Create">+ Ajouter un bien</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl" class="card-img-top" style="height:220px; object-fit:cover;" />

                    <div class="card-body">
                        <h5 class="card-title">@item.Title</h5>
                        <p><strong>Type :</strong> @item.Type</p>
                        <p><strong>Quartier :</strong> @item.Quarter</p>
                        <p><strong>Prix :</strong> @item.Price FCFA</p>
                        <span class="badge bg-success">@item.Status</span>
                    </div>

                    <div class="card-footer d-flex justify-content-between">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Voir fiche</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Supprimer</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>